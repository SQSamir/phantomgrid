# =============================================================================
# PHANTOMGRID — Environment Variables
# Copy to .env and fill in all values before starting.
# Generate JWT keys: make keys
# Generate MFA key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=phantomgrid
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=phantomgrid
POSTGRES_DSN=postgresql+asyncpg://phantomgrid:CHANGE_ME_STRONG_PASSWORD@postgres:5432/phantomgrid

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
# For production with SASL:
# KAFKA_SECURITY_PROTOCOL=SASL_PLAINTEXT
# KAFKA_SASL_MECHANISM=SCRAM-SHA-256
# KAFKA_SASL_USERNAME=phantomgrid
# KAFKA_SASL_PASSWORD=CHANGE_ME_KAFKA_PASSWORD

# --- JWT (RS256 preferred) ---
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public.pem
# Only set if NOT using RS256 keys (development only, min 32 chars):
# JWT_SECRET=CHANGE_ME_32_CHAR_MIN_SECRET_HERE

# --- MFA Encryption ---
MFA_ENCRYPTION_KEY=CHANGE_ME_FERNET_KEY_BASE64

# --- MinIO / Object Storage ---
MINIO_ROOT_USER=phantomgrid
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD

# --- Email (for notifications) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=alerts@example.com
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
SMTP_FROM=alerts@example.com

# --- Frontend ---
VITE_API_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8000
